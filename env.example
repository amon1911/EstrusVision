# =============================================================================
# Swine Estrus Detection Bot — Environment Configuration
# คัดลอกไฟล์นี้ไปเป็น .env แล้วกรอกค่าจริง
# =============================================================================

# ─── Telegram Bot ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# polling (dev) | webhook (production)
MODE=polling
WEBHOOK_URL=
WEBHOOK_PORT=8443
WEBHOOK_LISTEN=0.0.0.0

# ─── Gemini Vision ───────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=swine_estrus
DB_USER=postgres
DB_PASSWORD=Ksp2026

# ─── General ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
TEMP_IMAGE_DIR=./temp_images
SESSION_TIMEOUT_MINUTES=10

# ─── Feature Flags ───────────────────────────────────────────────────────────
# ENABLE_GILT_SELECTION
#   true  (default) → แสดงปุ่มให้ user เลือก "หมูสาว (Gilt)" / "หมูนาง (Sow)"
#   false           → ข้ามการเลือก → วิเคราะห์เป็น "หมูนาง (Sow)" อัตโนมัติ
ENABLE_GILT_SELECTION=true
LANGUAGE=TH

RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_SECONDS=60